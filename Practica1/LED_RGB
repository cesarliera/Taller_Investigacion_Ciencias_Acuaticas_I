int ledRojo = 2;
int ledVerde = 3;
int ledAzul = 4;
 
void setup() {
pinMode(ledRojo,OUTPUT);
pinMode(ledVerde,OUTPUT);
pinMode(ledAzul,OUTPUT);
}
 
void loop() {
//Prender color rojo
digitalWrite(ledRojo,255);
digitalWrite(ledVerde,0);
digitalWrite(ledAzul,0);
delay(1500);
//Apagar color rojo
digitalWrite(ledRojo,0);
digitalWrite(ledVerde,0);
digitalWrite(ledAzul,0);
delay(1500);
}
